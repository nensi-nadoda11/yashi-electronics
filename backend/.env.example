DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
PORT=4000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173
API_PREFIX=/api/v1
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="7d"
AUTH_COOKIE_NAME="yashi_customer_session"
AUTH_COOKIE_MAX_AGE_DAYS=7
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_SECURE=false
FRONTEND_URL="http://localhost:5173"
EMAIL_PROVIDER="smtp"
EMAIL_FROM_NAME="Yashi Electronics"
EMAIL_FROM_ADDRESS="no-reply@yashielectronics.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
RESET_PASSWORD_TOKEN_EXPIRY_MINUTES=30
